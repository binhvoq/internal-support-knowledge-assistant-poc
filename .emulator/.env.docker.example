# Copy thanh .env.docker (gitignored) va dien ENTRA_* tu config/azure.local.json sau:
#   cd infra/terraform && terraform init && terraform apply
# docker compose -f .emulator/docker-compose.yml --env-file .emulator/.env.docker up -d --build
# Buoc C: ENTRA_ENABLED=true + curl http://localhost:5003/ready -> "Entra outbound token acquired."

# Bat Entra de kiem tra saga reconcile snapshot co Bearer token
ENTRA_ENABLED=false

# entra.tenantId
ENTRA_TENANT_ID=

# entra.api.clientId (JWT audience / API app)
ENTRA_API_CLIENT_ID=

# entra.api.audience hoac identifierUri
ENTRA_API_AUDIENCE=

# entra.mcpService.clientId + clientSecret (Support.Service role)
ENTRA_MCP_CLIENT_ID=
ENTRA_MCP_CLIENT_SECRET=
