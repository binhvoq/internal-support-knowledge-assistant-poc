{
  "ServiceBus": {
    "ConnectionString": "Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;",
    "TopicName": "support-events"
  },
  "LocalMessaging": {
    "HttpBridgeEnabled": false,
    "TicketServiceBaseUrl": "http://localhost:5001",
    "AiOrchestratorBaseUrl": "http://localhost:5003"
  },
  "AzureSearch": {
    "Endpoint": "https://<search-name>.search.windows.net",
    "ApiKey": "<search-admin-key>",
    "IndexName": "knowledge-chunks",
    "DataSourceName": "knowledge-blob-datasource",
    "SkillsetName": "knowledge-pdf-skillset",
    "IndexerName": "knowledge-blob-indexer",
    "ChunkMaxPageLength": 1000,
    "ChunkPageOverlapLength": 200,
    "MmrRerankingEnabled": true,
    "MmrCandidateTop": 20,
    "MmrLambda": 0.5,
    "IngestionPollTimeoutSeconds": 120,
    "AdminApiVersion": "2024-07-01"
  },
  "AzureOpenAI": {
    "Endpoint": "https://<openai-embed-account>.openai.azure.com/",
    "ApiKey": "<openai-embed-key>",
    "ChatEndpoint": "https://<openai-chat-account>.openai.azure.com/",
    "ChatApiKey": "<openai-chat-key>",
    "ChatDeployment": "gpt-4.1-mini",
    "EmbeddingDeployment": "text-embedding-3-small",
    "EmbeddingModelName": "text-embedding-3-small",
    "EmbeddingDimensions": 1536
  },
  "AzureStorage": {
    "ConnectionString": "<storage-connection-string>",
    "ContainerName": "knowledge-docs"
  },
  "Services": {
    "AiOrchestrator": "http://localhost:5003",
    "TicketService": "http://localhost:5001",
    "KnowledgeService": "http://localhost:5002",
    "McpToolServer": "http://localhost:5004"
  },
  "ConnectionStrings": {
    "Tickets": "Data Source=tickets.db",
    "Knowledge": "Data Source=knowledge.db"
  }
}
