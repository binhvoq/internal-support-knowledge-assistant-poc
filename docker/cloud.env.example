# Copy to docker/cloud.env and fill values from config/azure.local.json after Terraform apply.
# Keep SQL Server and Service Bus local via compose.yaml; these values enable Entra + cloud AI/Search.

AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
AAD_AUTHORITY=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000
AAD_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
AAD_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000
AAD_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
AAD_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000
AAD_MCP_CLIENT_ID=00000000-0000-0000-0000-000000000000
AAD_MCP_CLIENT_SECRET=replace-me

AZURE_SEARCH_ENDPOINT=https://support-search-dev01.search.windows.net
AZURE_SEARCH_API_KEY=replace-me
AZURE_SEARCH_INDEX_NAME=knowledge-chunks

AZURE_OPENAI_ENDPOINT=https://support-oai-embed-dev01.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_ENDPOINT=https://support-oai-chat-dev01.openai.azure.com/
AZURE_OPENAI_CHAT_API_KEY=replace-me
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini

AZURE_STORAGE_CONNECTION_STRING=replace-me
APPLICATIONINSIGHTS_CONNECTION_STRING=replace-me
